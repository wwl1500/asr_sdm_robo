<?xml version="1.0" ?>
<!--
  Four-link, three-physical-joint underwater snake robot URDF.
  Matches the dynamics derivation document:
    n = 4 propulsion links, n-1 = 3 physical joints (each pitch + yaw)
    Joint coordinates: θ1(pitch), θ2(yaw), θ3(pitch), θ4(yaw), θ5(pitch), θ6(yaw)
    FreeFlyer base 6 DOF => core ζ ∈ R^12
    
  Each link frame is at its centroid, x-axis along link centerline.
  Link length Λ = 0.3m, so L_{i,1} = L_{i,2} = 0.15m.
  
  Visual: cylinder bodies + .dae screw propeller meshes.
-->
<robot name="underwater_snakerobot_4link" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ======================= Link 1 (base_link / head) ======================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.015" ixy="0" ixz="0"
               iyy="0.015" iyz="0"
               izz="0.0036"/>
    </inertial>
    <visual name="body1">
      <origin xyz="-0.025 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.25"/>
      </geometry>
      <material name="link1_color">
        <color rgba="0.15 0.35 0.65 1.0"/>
      </material>
    </visual>
    <!-- Torpedo nose cone -->
    <visual name="nose_cone">
      <origin xyz="0.125 0 0" rpy="0 -1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.10"/>
      </geometry>
      <material name="nose_color">
        <color rgba="0.10 0.25 0.50 1.0"/>
      </material>
    </visual>
    <!-- Nose tip sphere -->
    <visual name="nose_tip">
      <origin xyz="0.18 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="nose_tip_color">
        <color rgba="0.90 0.20 0.20 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <!-- Screw propellers on Link 1 -->
  <link name="screw_1_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_left_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <link name="screw_1_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_right_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <joint name="link1_to_screw_1_left" type="continuous">
    <parent link="base_link"/>
    <child link="screw_1_left"/>
    <origin xyz="0.10 0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>
  <joint name="link1_to_screw_1_right" type="continuous">
    <parent link="base_link"/>
    <child link="screw_1_right"/>
    <origin xyz="0.10 -0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- ============= Joint 1 (Link 1 → Link 2): θ1(pitch), θ2(yaw) ============= -->
  <link name="joint1_intermediate">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-8" ixy="0" ixz="0" iyy="1e-8" iyz="0" izz="1e-8"/>
    </inertial>
    <visual name="joint1_sphere">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="joint_color">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint1_pitch" type="revolute">
    <parent link="base_link"/>
    <child link="joint1_intermediate"/>
    <origin xyz="-0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0"/>
  </joint>
  <joint name="joint1_yaw" type="revolute">
    <parent link="joint1_intermediate"/>
    <child link="link_2"/>
    <origin xyz="-0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0"/>
  </joint>

  <!-- ======================= Link 2 ======================= -->
  <link name="link_2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.015" ixy="0" ixz="0"
               iyy="0.015" iyz="0"
               izz="0.0036"/>
    </inertial>
    <visual name="body2">
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
      <material name="link2_color">
        <color rgba="0.35 0.65 0.40 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <link name="screw_2_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_left_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <link name="screw_2_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_right_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <joint name="link2_to_screw_2_left" type="continuous">
    <parent link="link_2"/>
    <child link="screw_2_left"/>
    <origin xyz="0.10 0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>
  <joint name="link2_to_screw_2_right" type="continuous">
    <parent link="link_2"/>
    <child link="screw_2_right"/>
    <origin xyz="0.10 -0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- ============= Joint 2 (Link 2 → Link 3): θ3(pitch), θ4(yaw) ============= -->
  <link name="joint2_intermediate">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-8" ixy="0" ixz="0" iyy="1e-8" iyz="0" izz="1e-8"/>
    </inertial>
    <visual name="joint2_sphere">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="joint_color">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint2_pitch" type="revolute">
    <parent link="link_2"/>
    <child link="joint2_intermediate"/>
    <origin xyz="-0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0"/>
  </joint>
  <joint name="joint2_yaw" type="revolute">
    <parent link="joint2_intermediate"/>
    <child link="link_3"/>
    <origin xyz="-0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0"/>
  </joint>

  <!-- ======================= Link 3 ======================= -->
  <link name="link_3">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.015" ixy="0" ixz="0"
               iyy="0.015" iyz="0"
               izz="0.0036"/>
    </inertial>
    <visual name="body3">
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
      <material name="link3_color">
        <color rgba="0.75 0.45 0.30 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <link name="screw_3_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_left_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <link name="screw_3_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_right_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <joint name="link3_to_screw_3_left" type="continuous">
    <parent link="link_3"/>
    <child link="screw_3_left"/>
    <origin xyz="0.10 0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>
  <joint name="link3_to_screw_3_right" type="continuous">
    <parent link="link_3"/>
    <child link="screw_3_right"/>
    <origin xyz="0.10 -0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <!-- ============= Joint 3 (Link 3 → Link 4): θ5(pitch), θ6(yaw) ============= -->
  <link name="joint3_intermediate">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-8" ixy="0" ixz="0" iyy="1e-8" iyz="0" izz="1e-8"/>
    </inertial>
    <visual name="joint3_sphere">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="joint_color">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="joint3_pitch" type="revolute">
    <parent link="link_3"/>
    <child link="joint3_intermediate"/>
    <origin xyz="-0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0"/>
  </joint>
  <joint name="joint3_yaw" type="revolute">
    <parent link="joint3_intermediate"/>
    <child link="link_4"/>
    <origin xyz="-0.15 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="10.0"/>
  </joint>

  <!-- ======================= Link 4 (tail) ======================= -->
  <link name="link_4">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.015" ixy="0" ixz="0"
               iyy="0.015" iyz="0"
               izz="0.0036"/>
    </inertial>
    <visual name="body4">
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
      <material name="link4_color">
        <color rgba="0.80 0.60 0.20 1.0"/>
      </material>
    </visual>
    <!-- Rear cap (hemisphere) -->
    <visual name="cap4_rear">
      <origin xyz="-0.15 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
      <material name="link4_color">
        <color rgba="0.80 0.60 0.20 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <link name="screw_4_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_left_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <link name="screw_4_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <mesh filename="package://asr_sdm_description/meshes/screw_right_CFD.dae"/>
      </geometry>
    </visual>
  </link>
  <joint name="link4_to_screw_4_left" type="continuous">
    <parent link="link_4"/>
    <child link="screw_4_left"/>
    <origin xyz="0.10 0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>
  <joint name="link4_to_screw_4_right" type="continuous">
    <parent link="link_4"/>
    <child link="screw_4_right"/>
    <origin xyz="0.10 -0.07 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

</robot>
